# pantau-alexa — default environment variables
# Copy to .env and fill in the required values.
# All variables use the PANTAU_ prefix.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PANTAU_HOST=0.0.0.0
PANTAU_PORT=8080
PANTAU_DEBUG=false

# Path to the device registry YAML (absolute or relative to the project root)
PANTAU_DEVICES_CONFIG_PATH=config/devices.yaml

# ---------------------------------------------------------------------------
# Security  (REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))")
# ---------------------------------------------------------------------------
# When set, /alexa/directive additionally requires HMAC-SHA256 request signing
# (X-Pantau-Timestamp / X-Pantau-Signature headers); empty disables HMAC.
PANTAU_SHARED_SECRET=
# Replay-protection window for the HMAC timestamp, in seconds.
PANTAU_HMAC_TOLERANCE_SECONDS=300

# ---------------------------------------------------------------------------
# Rate limiting (OAuth login + token endpoints, per client IP / username)
# ---------------------------------------------------------------------------
PANTAU_RATE_LIMIT_MAX_ATTEMPTS=10
PANTAU_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# REQUIRED in production (min 32 chars) — the server refuses to start when
# empty or too short unless PANTAU_DEV_MODE=true.
PANTAU_JWT_SECRET=
PANTAU_JWT_ALGORITHM=HS256
PANTAU_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
PANTAU_JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# OAuth
# ---------------------------------------------------------------------------
# Comma-separated list of allowed redirect URIs.
# REQUIRED in production — omitting this (with DEV_MODE=false) blocks all OAuth requests.
PANTAU_OAUTH_ALLOWED_REDIRECT_URIS=

# Set to true ONLY for local development to skip the redirect_uri allowlist check.
# NEVER enable in production.
PANTAU_DEV_MODE=false

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
PANTAU_USERS_DB_PATH=pantau_users.db

# ---------------------------------------------------------------------------
# AWS / S3 beacon
# ---------------------------------------------------------------------------
PANTAU_AWS_REGION=eu-central-1
PANTAU_S3_BEACON_BUCKET=pantau-alexa-beacon
PANTAU_S3_BEACON_KEY=endpoint.json
