# tiberio — default environment variables
# Copy to .env and fill in the required values.
# All variables use the TIBERIO_ prefix.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
TIBERIO_HOST=0.0.0.0
TIBERIO_PORT=8080
TIBERIO_DEBUG=false

# Path to the device registry YAML (absolute or relative to the project root)
TIBERIO_DEVICES_CONFIG_PATH=config/devices.yaml

# ---------------------------------------------------------------------------
# Security  (REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))")
# ---------------------------------------------------------------------------
# When set, /alexa/directive additionally requires HMAC-SHA256 request signing
# (X-Tiberio-Timestamp / X-Tiberio-Signature headers); empty disables HMAC.
TIBERIO_SHARED_SECRET=
# Replay-protection window for the HMAC timestamp, in seconds.
TIBERIO_HMAC_TOLERANCE_SECONDS=300

# ---------------------------------------------------------------------------
# Rate limiting (OAuth login + token endpoints, per client IP / username)
# ---------------------------------------------------------------------------
TIBERIO_RATE_LIMIT_MAX_ATTEMPTS=10
TIBERIO_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# REQUIRED in production (min 32 chars) — the server refuses to start when
# empty or too short unless TIBERIO_DEV_MODE=true.
TIBERIO_JWT_SECRET=
TIBERIO_JWT_ALGORITHM=HS256
TIBERIO_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
TIBERIO_JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# OAuth
# ---------------------------------------------------------------------------
# Comma-separated list of allowed redirect URIs.
# REQUIRED in production — omitting this (with DEV_MODE=false) blocks all OAuth requests.
TIBERIO_OAUTH_ALLOWED_REDIRECT_URIS=

# Set to true ONLY for local development to skip the redirect_uri allowlist check.
# NEVER enable in production.
TIBERIO_DEV_MODE=false

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
TIBERIO_USERS_DB_PATH=tiberio_users.db

# ---------------------------------------------------------------------------
# AWS / S3 beacon
# ---------------------------------------------------------------------------
TIBERIO_AWS_REGION=eu-central-1
TIBERIO_S3_BEACON_BUCKET=tiberio-beacon
TIBERIO_S3_BEACON_KEY=endpoint.json
